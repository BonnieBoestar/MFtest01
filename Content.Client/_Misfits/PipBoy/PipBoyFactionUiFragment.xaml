<pipboy:PipBoyFactionUiFragment
    xmlns="https://spacestation14.io"
    xmlns:pipboy="clr-namespace:Content.Client._Misfits.PipBoy"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
    Orientation="Vertical"
    HorizontalExpand="True"
    VerticalExpand="True"
    Margin="5">

    <Label Name="LockedLabel"
           Text="{Loc pipboy-hub-locked-title}"
           StyleClasses="LabelHeading"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"
           Visible="False" />

    <BoxContainer Name="MainPanel"
                  Orientation="Vertical"
                  HorizontalExpand="True"
                  VerticalExpand="True">
        <controls:StripeBack MinSize="48 48" VerticalExpand="False">
            <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                <Label Name="TitleLabel"
                       Text="{Loc pipboy-faction-program-name}"
                       StyleClasses="LabelHeading"
                       HorizontalExpand="True"
                       Margin="8 0"
                       VerticalAlignment="Center" />
                <Label Name="OwnNumberLabel"
                       Text="#0000"
                       StyleClasses="LabelSubText"
                       VerticalAlignment="Center"
                       Margin="0 0 8 0" />
            </BoxContainer>
        </controls:StripeBack>

        <Label Name="UnavailableLabel"
               Text="{Loc pipboy-faction-unavailable}"
               StyleClasses="LabelSubText"
               HorizontalAlignment="Center"
               Margin="0 8"
               Visible="False" />

        <BoxContainer Name="FactionPanel"
                      Orientation="Vertical"
                      HorizontalExpand="True"
                      VerticalExpand="True">
            <TabContainer Name="FactionTabs"
                          HorizontalExpand="True"
                          VerticalExpand="True"
                          Margin="0 2 0 0">
                <PanelContainer StyleClasses="AngleRect">
                    <BoxContainer Orientation="Horizontal" Margin="6" HorizontalExpand="True" VerticalExpand="True">
                        <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True" Margin="0 0 4 0">
                            <Label Text="{Loc pipboy-faction-roster-header}"
                                   StyleClasses="LabelHeading"
                                   Margin="0 0 0 4" />
                            <LineEdit Name="FactionMemberSearch"
                                      PlaceHolder="{Loc pipboy-faction-member-search-placeholder}"
                                      HorizontalExpand="True"
                                      Margin="0 0 0 4" />
                            <ScrollContainer HorizontalExpand="True" VerticalExpand="True" HScrollEnabled="False">
                                <GridContainer Name="FactionRosterGrid"
                                               Columns="2"
                                               HSeparationOverride="4"
                                               VSeparationOverride="4"
                                               HorizontalExpand="True"
                                               VerticalExpand="True" />
                            </ScrollContainer>
                        </BoxContainer>

                        <PanelContainer StyleClasses="AngleRect" MinWidth="230">
                            <BoxContainer Orientation="Vertical" Margin="6" HorizontalExpand="True" VerticalExpand="True">
                                <Label Text="{Loc pipboy-faction-alerts-header}"
                                       StyleClasses="LabelHeading"
                                       Margin="0 0 0 4" />
                                <ScrollContainer HorizontalExpand="True" VerticalExpand="True" HScrollEnabled="False">
                                    <BoxContainer Name="FactionAlertsList"
                                                  Orientation="Vertical"
                                                  HorizontalExpand="True"
                                                  VerticalExpand="True" />
                                </ScrollContainer>
                            </BoxContainer>
                        </PanelContainer>
                    </BoxContainer>
                </PanelContainer>

                <PanelContainer StyleClasses="AngleRect">
                    <BoxContainer Orientation="Vertical" Margin="6" HorizontalExpand="True" VerticalExpand="True">
                        <GridContainer Columns="2"
                                       HSeparationOverride="6"
                                       HorizontalExpand="True"
                                       VerticalExpand="True">
                            <ScrollContainer Name="FactionAnnouncementsScroll"
                                             HorizontalExpand="True"
                                             VerticalExpand="True"
                                             HScrollEnabled="False">
                                <BoxContainer Name="FactionAnnouncementsList"
                                              Orientation="Vertical"
                                              HorizontalExpand="True"
                                              VerticalExpand="True" />
                            </ScrollContainer>
                        </GridContainer>

                        <PanelContainer StyleClasses="AngleRect" Margin="0 6 0 0">
                            <BoxContainer Orientation="Vertical" Margin="6" HorizontalExpand="True">
                                <LineEdit Name="FactionMessageInput"
                                          PlaceHolder="{Loc pipboy-faction-message-placeholder}"
                                          HorizontalExpand="True"
                                          Margin="0 0 0 2" />
                                <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                                    <Button Name="FactionSendBtn"
                                            Text="{Loc pipboy-faction-send}"
                                            HorizontalExpand="True"
                                            StyleClasses="OpenRight" />
                                    <Button Name="FactionAnnounceBtn"
                                            Text="{Loc pipboy-faction-announce}"
                                            HorizontalExpand="True"
                                            Margin="2 0 0 0"
                                            StyleClasses="OpenLeft" />
                                </BoxContainer>
                            </BoxContainer>
                        </PanelContainer>
                    </BoxContainer>
                </PanelContainer>

                <PanelContainer StyleClasses="AngleRect">
                    <BoxContainer Orientation="Vertical" Margin="6" HorizontalExpand="True" VerticalExpand="True">
                        <ScrollContainer Name="FactionGeneralScroll"
                                         HorizontalExpand="True"
                                         VerticalExpand="True"
                                         HScrollEnabled="False">
                            <BoxContainer Name="FactionGeneralList"
                                          Orientation="Vertical"
                                          HorizontalExpand="True"
                                          VerticalExpand="True" />
                        </ScrollContainer>
                    </BoxContainer>
                </PanelContainer>

                <PanelContainer StyleClasses="AngleRect">
                    <BoxContainer Orientation="Vertical" Margin="6" HorizontalExpand="True" VerticalExpand="True">
                        <Label Text="{Loc pipboy-faction-tasks-header}"
                               StyleClasses="LabelHeading"
                               Margin="0 0 0 4" />
                        <ScrollContainer HorizontalExpand="True" VerticalExpand="True" HScrollEnabled="False">
                            <BoxContainer Name="FactionTasksList"
                                          Orientation="Vertical"
                                          HorizontalExpand="True"
                                          VerticalExpand="True" />
                        </ScrollContainer>
                        <LineEdit Name="FactionTaskInput"
                                  PlaceHolder="{Loc pipboy-faction-task-placeholder}"
                                  HorizontalExpand="True"
                                  Margin="0 4 0 2" />
                        <OptionButton Name="FactionTaskAssignee"
                                      HorizontalExpand="True"
                                      Margin="0 0 0 2" />
                        <Button Name="FactionTaskCreateBtn"
                                Text="{Loc pipboy-faction-task-create}"
                                HorizontalExpand="True" />
                    </BoxContainer>
                </PanelContainer>
            </TabContainer>
        </BoxContainer>
    </BoxContainer>
</pipboy:PipBoyFactionUiFragment>
